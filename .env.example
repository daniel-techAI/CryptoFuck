# Browser/API origin allowed by the Express service (comma-separated when needed).
APP_ORIGIN=http://127.0.0.1:5173
PORT=8787

# Public browser configuration for optional Supabase Auth + cloud profiles.
# Use the publishable key (or legacy anon key), never a service-role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Live execution is disabled by default. Keep it disabled through paper validation.
LIVE_TRADING_ENABLED=false
EXCHANGE_ID=kraken
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
TRADING_ARM_TOKEN=
LIVE_ACCOUNT_EQUITY_USD=

# Without this exact acknowledgement, the CCXT adapter attempts sandbox mode.
LIVE_PRODUCTION_ACK=
